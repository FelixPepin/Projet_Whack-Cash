<Window x:Class="Whack_Cash.FenetreBoutique"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Whack_Cash"
        mc:Ignorable="d"
        Title="FenetreBoutique" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="401*"/>
            <RowDefinition Height="33*"/>
        </Grid.RowDefinitions>
        <Grid.Background>
            <ImageBrush ImageSource="Images/boutique.png"/>
        </Grid.Background>
        <ListBox x:Name="lst_items" HorizontalAlignment="Left" Height="216" Margin="18,152,0,0" VerticalAlignment="Top" Width="333" SelectionChanged="lst_items_SelectionChanged"/>
        <Image Source="/Images/btn_acheter.png" Margin="-101,330,512,-47" Grid.RowSpan="2"/>
        <Button x:Name="btn_acheter" HorizontalAlignment="Left" Margin="21,380,0,0" VerticalAlignment="Top" Width="142" Height="52" OverridesDefaultStyle="True" 
        Background="Transparent" Focusable="False" Grid.RowSpan="2" Click="btn_acheter_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <Image Source="/Images/btn_retour_boutique.png" Margin="67,327,322,-50" Grid.RowSpan="2"/>
        <Button x:Name="btn_retour" HorizontalAlignment="Left" Margin="202,384,0,0" VerticalAlignment="Top" Width="142" Height="44" OverridesDefaultStyle="True" 
            Background="Transparent" Focusable="False" Grid.RowSpan="2" Click="btn_retour_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <TextBlock x:Name="txt_prix" FontSize="36" Foreground="White" HorizontalAlignment="Left" Height="58" Margin="21,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="194"><Run Text=""/><LineBreak/><Run/></TextBlock>
        <TextBlock x:Name="txt_degat" FontSize="36" Foreground="White" HorizontalAlignment="Left" Height="58" Margin="21,65,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="197" Text=""/>
        <TextBlock x:Name="txt_type" FontSize="36" Foreground="White" HorizontalAlignment="Left" Height="58" Margin="240,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="304"><Run Text=""/><LineBreak/><Run/></TextBlock>
        <TextBlock x:Name="txt_tour" FontSize="36" Foreground="White" HorizontalAlignment="Left" Height="58" Margin="240,65,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="258"><Run Text=""/><LineBreak/><Run/></TextBlock>
        <TextBlock x:Name="txtArgent" Text="💰 0 $" FontSize="24" FontWeight="Bold" Foreground="Gold" Margin="662,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
    </Grid>
</Window>
