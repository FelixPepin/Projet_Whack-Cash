<Window x:Class="Whack_Cash.FenetreTutoriel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Whack_Cash"
        mc:Ignorable="d"
        Title="FenetreTutoriel" Height="450" Width="800"
        KeyDown="Window_KeyDown"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/bg_tuto.png"/>
        </Grid.Background>
        <MediaElement HorizontalAlignment="Center" Height="275" Margin="0,61,0,0" VerticalAlignment="Top" Width="499" Source="Video/tutoriel.mp4" LoadedBehavior="Play"
              UnloadedBehavior="Stop"/>
        <TextBlock HorizontalAlignment="Center" Margin="0,3,0,0" TextWrapping="Wrap" Text="Tutoriel" VerticalAlignment="Top" Height="51" Width="157" Foreground="White"
                   FontSize="40" Background="Black" TextAlignment="Center"/>
        <Image Source="/Images/btn_retour.png" Stretch="Fill" Height="180" VerticalAlignment="Top" Margin="284,296,284,0" />
        <Button x:Name="btn_retour" HorizontalAlignment="Left" VerticalAlignment="Top" Width="170" Height="53" OverridesDefaultStyle="True" 
Background="Transparent" Focusable="False" Click="btn_retour_Click" Margin="308,359,0,0" >
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>
