<Window x:Class="Whack_Cash.FenetreConnexion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Whack_Cash"
        mc:Ignorable="d"
        Title="FenetreConnexion" Height="450" Width="800"
        KeyDown="Window_KeyDown"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/Connexion_bg.png"/>
        </Grid.Background>
        <Label Content="Nom :" HorizontalAlignment="Left" Height="27" Margin="234,126,0,0" VerticalAlignment="Top" Width="53" Foreground="White"/>
        <Label Content="Mot de passe :" HorizontalAlignment="Left" Height="39" Margin="234,188,0,0" VerticalAlignment="Top" Width="238" Foreground="White"/>
        <Image x:Name="img_btn_connexion" Source="/Images/btn_connexion.png" Stretch="Fill" Height="343" VerticalAlignment="Top" Margin="159,170,159,0" />
        <Button x:Name="btn_connexion" HorizontalAlignment="Left" Margin="203,299,0,0" VerticalAlignment="Top" Width="385" Height="90" OverridesDefaultStyle="True" 
            Background="Transparent" Focusable="False" Click="btn_connexion_Click" MouseEnter="btn_entre" MouseLeave="btn_quitte">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <TextBox x:Name="txt_nom" HorizontalAlignment="Center" Height="34" Margin="0,153,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="332"/>
        <PasswordBox x:Name="txt_mdp" HorizontalAlignment="Center" Height="34" VerticalAlignment="Top" Width="332" Margin="0,217,0,0"/>
    </Grid>
</Window>
