<Window x:Class="Whack_Cash.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Whack_Cash"
        mc:Ignorable="d"
        Title="Menu Principale Whack &amp; Cash" Height="450" Width="800"
        Background="Black">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="250" Height="449">
        <StackPanel x:Name="txt_nom">
            <TextBlock TextWrapping="Wrap" Text="Whack &amp; Cash" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30" Foreground="#FFF7F7F7"/>
            <Button x:Name="btn_jouer" Content="Jouer" FontSize="20" Background="#FF0031F7" Foreground="White" Margin="0,0,0,20" Width="250" Height="40" Click="btn_jouer_Click"/>
            <Button x:Name="btn_univers" Content="Univers" FontSize="20" Background="#FF0031F7" Foreground="White" Margin="0,0,0,20" Height="40"/>
            <Button x:Name="btn_leaderboard" Content="Leaderboard" FontSize="20" Background="#FF0031F7" Foreground="White" Margin="0,0,0,20" Height="40"/>
            <Button x:Name="btn_connexion" Content="Connexion" FontSize="20" Background="#FF0031F7" Foreground="White" Margin="0,0,0,20" Height="40"/>
            <Button x:Name="btn_credits" Content="Crédits" FontSize="20" Background="#FF0031F7" Foreground="White" Margin="0,0,0,20" Height="40"/>
            <Button x:Name="btn_quitter" Content="Quitter" FontSize="20" Background="Red" Foreground="White" Margin="0,0,0,20" Height="40"/>

        </StackPanel>

    </Grid>
</Window>
