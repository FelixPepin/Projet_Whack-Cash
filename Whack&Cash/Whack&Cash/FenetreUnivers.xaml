<Window x:Class="Whack_Cash.FenetreUnivers"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Whack_Cash"
        mc:Ignorable="d"
        Title="FenetreUnivers" Height="450" Width="800"
        KeyDown="Window_KeyDown"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/univers_bg.png"/>
        </Grid.Background>
        <Image Source="/Images/btn_star_wars.png" Stretch="Fill" Height="122" VerticalAlignment="Top" Margin="501,40,93,0" />
        <Button x:Name="btn_star_wars" HorizontalAlignment="Left" Margin="522,80,0,0" VerticalAlignment="Top" Width="164" Height="42" OverridesDefaultStyle="True" 
        Background="Transparent" Focusable="False" Click="btn_star_wars_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <Image Source="/Images/btn_gaming.png" Stretch="Fill" Height="122" VerticalAlignment="Top" Margin="82,264,512,0" />
        <Button x:Name="btn_gaming" HorizontalAlignment="Left" Margin="103,301,0,0" VerticalAlignment="Top" Width="163" Height="53" OverridesDefaultStyle="True" 
        Background="Transparent" Focusable="False" Click="btn_gaming_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <Image Source="/Images/btn_fantaisie.png" Stretch="Fill" Height="122" VerticalAlignment="Top" Margin="82,40,512,0" />
        <Button x:Name="btn_fantaisie" HorizontalAlignment="Left" Margin="104,80,0,0" VerticalAlignment="Top" Width="162" Height="42" OverridesDefaultStyle="True" 
        Background="Transparent" Focusable="False" Click="btn_fantaisie_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <Image Source="/Images/btn_anime.png" Stretch="Fill" Height="122" VerticalAlignment="Top" Margin="501,266,93,0" />
        <Button x:Name="btn_anime" HorizontalAlignment="Left" Margin="522,301,0,0" VerticalAlignment="Top" Width="163" Height="53" OverridesDefaultStyle="True" 
        Background="Transparent" Focusable="False" Click="btn_anime_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <Image Source="/Images/btn_retour.png" Stretch="Fill" Height="180" VerticalAlignment="Center" Margin="291,0,277,0" />
        <Button x:Name="btn_retour" HorizontalAlignment="Center" VerticalAlignment="Center" Width="170" Height="53" OverridesDefaultStyle="True" 
        Background="Transparent" Focusable="False" Click="btn_retour_Click" >
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>
