<Window x:Class="Whack_Cash.FenetreInscription"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Whack_Cash"
        mc:Ignorable="d"
        Title="FenetreInscription" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/bg_inscription.png"/>
        </Grid.Background>
        <Label Content="Nom :" HorizontalAlignment="Left" Height="27" Margin="234,126,0,0" VerticalAlignment="Top" Width="53" Foreground="White"/>
        <Label Content="Mot de passe :" HorizontalAlignment="Left" Height="39" Margin="234,188,0,0" VerticalAlignment="Top" Width="238" Foreground="White"/>
        <Label Content="Confirmation mot de passe :" HorizontalAlignment="Left" Height="39" Margin="234,252,0,0" VerticalAlignment="Top" Width="238" Foreground="White"/>
        <Image Source="/Images/btn_inscription.png" Stretch="Fill" Height="296" VerticalAlignment="Top" Margin="196,227,196,0" />
        <Button x:Name="btn_inscription" HorizontalAlignment="Center" Margin="0,335,0,0" VerticalAlignment="Top" Width="332" Height="70" OverridesDefaultStyle="True" 
        Background="Transparent" Focusable="False" Click="btn_inscription_Click" >
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <TextBox x:Name="txt_nom" HorizontalAlignment="Center" Height="34" Margin="0,153,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="332"/>
        <PasswordBox x:Name="txt_mdp" HorizontalAlignment="Center" Height="34" VerticalAlignment="Top" Width="332" Margin="0,217,0,0"/>
        <PasswordBox x:Name="txt_mdpConfirmation" HorizontalAlignment="Center" Height="34" VerticalAlignment="Top" Width="332" Margin="0,280,0,0"/>
    </Grid>
</Window>
